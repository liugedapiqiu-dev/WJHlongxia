});

// ============ 会话追踪功能 ============

// 存储活跃会话
let activeSessions = {};
const SESSION_TIMEOUT = 30 * 60 * 1000; // 30 分钟超时

// 任务队列数据
let queueData = {
  queueAhead: 0,      // 队列中等待的任务数
  waitedMs: 0,        // 当前等待时间
  lanes: {},          // 各通道队列状态
  lastUpdate: Date.now()
};

// 从日志中提取会话信息
function extractSessionInfo(logLine) {
  try {
    const parsed = JSON.parse(logLine);
    const mainContent = parsed['0'] || '';
    const time = parsed.time ? new Date(parsed.time).getTime() : Date.now();
    
    // 检测私聊会话
    if (mainContent.includes('User entered P2P chat')) {
      const chatMatch = mainContent.match(/chat_id[":\s]+([^"\s,]+)/);
      const userMatch = mainContent.match(/user_id[":\s]+([^"\s,]+)/);
      if (chatMatch && userMatch) {
        return {
          type: 'p2p',
          chatId: chatMatch[1],
          userId: userMatch[1],
          time: time
        };
      }
    }
    
    // 检测消息已读
    if (mainContent.includes('Message read event')) {
      const chatMatch = mainContent.match(/chat_id[":\s]+([^"\s,]+)/);
      const userMatch = mainContent.match(/user_id[":\s]+([^"\s,]+)/);
      if (chatMatch && userMatch) {
        return {
          type: 'read',
          chatId: chatMatch[1],
          userId: userMatch[1],
          time: time
        };
      }
    }
  } catch (e) {}
  return null;
}

// 从日志中提取队列信息
function extractQueueInfo(logLine) {
  try {
    const parsed = JSON.parse(logLine);
    const mainContent = parsed['1'] || parsed['0'] || '';
    
    // 检测队列等待日志
    if (mainContent.includes('lane wait exceeded')) {
      const laneMatch = mainContent.match(/lane=([^\s]+)/);
      const waitedMatch = mainContent.match(/waitedMs=(\d+)/);
      const queueMatch = mainContent.match(/queueAhead=(\d+)/);
      
      if (laneMatch && waitedMatch && queueMatch) {
        const lane = laneMatch[1];
        const waitedMs = parseInt(waitedMatch[1]);
        const queueAhead = parseInt(queueMatch[1]);
        
        queueData.lanes[lane] = {
          queueAhead,
          waitedMs,
          lastUpdate: Date.now()
        };
        
        // 更新总体队列状态
        queueData.queueAhead = Object.values(queueData.lanes)
          .reduce((sum, l) => sum + l.queueAhead, 0);
        queueData.waitedMs = Math.max(...Object.values(queueData.lanes).map(l => l.waitedMs), 0);
        queueData.lastUpdate = Date.now();
        
        return true;
      }
    }
  } catch (e) {}
  return false;
}

// 更新会话数据
function updateSession(sessionInfo) {
  if (!sessionInfo) return;
  
  const key = sessionInfo.chatId;
  if (!activeSessions[key]) {
    activeSessions[key] = {
      chatId: sessionInfo.chatId,
      userId: sessionInfo.userId,
      lastActive: sessionInfo.time,
      messageCount: 0,
      events: []
    };
  }
  
  activeSessions[key].lastActive = sessionInfo.time;
  activeSessions[key].messageCount++;
  activeSessions[key].events.push({
    type: sessionInfo.type,
    time: sessionInfo.time
  });
  
  // 保留最近 10 个事件
  if (activeSessions[key].events.length > 10) {
    activeSessions[key].events.shift();
  }
  
  // 广播会话更新
  broadcast(JSON.stringify({
    type: 'sessions',
    data: getSessionsList()
  }));
}

// 获取会话列表
function getSessionsList() {
  const now = Date.now();
  return Object.values(activeSessions)
    .filter(s => now - s.lastActive < SESSION_TIMEOUT)
    .sort((a, b) => b.lastActive - a.lastActive)
    .map(s => ({
      ...s,
      lastActiveStr: new Date(s.lastActive).toLocaleTimeString('zh-CN')
    }));
}

// 在日志监控中集成会话追踪
const originalStartLogMonitoring = global.startLogMonitoring;
global.startLogMonitoring = function() {
  // 会在全局 scope 执行，不需要额外处理
};
